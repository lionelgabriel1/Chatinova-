{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://178.104.98.89:80/api/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/((?!api/|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
